# elk_2_vlogs configuration
# Copy this file to .env, fill in your values, and run ./elk_2_vlogs.sh
# All variables are optional — unset ones fall back to the script defaults.

# Elasticsearch
#ES_HOST=http://localhost:9200
#ES_INDEX=your-index-name
#ES_USER=elastic
#ES_PASS=password
#TIMESTAMP_FIELD=@timestamp

# VictoriaLogs
#VL_HOST=http://localhost:9428

# Migration window (ISO 8601)
#START_DATE=2024-01-01T00:00:00.000Z
#END_DATE=2024-01-31T23:59:59.999Z

# Parallelism
# Defaults to the number of available CPU cores.
# MAX_WORKERS=8

# VictoriaLogs field mapping
# VL_STREAM_FIELDS=data_stream.type,data_stream.dataset,data_stream.namespace
# VL_MSG_FIELD=event.original
# VL_EXTRA_FIELDS=source=migration

# Multi-tenancy (leave blank for single-tenant)
# VL_ACCOUNT_ID=
# VL_PROJECT_ID=

# Debugging
# DEBUG_MODE=false
